# Number Rush — public Expo env names only (safe to commit as example).
# Copy to `.env` locally. Never put secrets in EXPO_PUBLIC_* variables.

# development | preview | production
EXPO_PUBLIC_APP_ENV=development

# App version string surfaced in feedback / about UI
EXPO_PUBLIC_APP_VERSION=1.0.0

# When true, enables analytics adapter (still local/no-op unless a vendor is wired)
EXPO_PUBLIC_ANALYTICS_ENABLED=false

# When true, enables error reporting path (no vendor wired by default)
EXPO_PUBLIC_ERROR_REPORTING_ENABLED=false

# Hosted legal URLs (https). Required for production env validation.
EXPO_PUBLIC_PRIVACY_POLICY_URL=
EXPO_PUBLIC_TERMS_URL=
