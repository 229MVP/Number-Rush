# Number Rush — public Expo env names only (safe to commit as example).
# Copy to `.env` locally. Never put secrets in EXPO_PUBLIC_* variables.

# development | preview | production
EXPO_PUBLIC_APP_ENV=development

# App version string surfaced in feedback / about UI
EXPO_PUBLIC_APP_VERSION=1.0.0

# When true, enables analytics adapter (still local/no-op unless a vendor is wired)
EXPO_PUBLIC_ANALYTICS_ENABLED=false

# When true, enables error reporting path (no vendor wired by default)
EXPO_PUBLIC_ERROR_REPORTING_ENABLED=false

# Hosted legal URLs (https). Required for production env validation.
EXPO_PUBLIC_PRIVACY_POLICY_URL=
EXPO_PUBLIC_TERMS_URL=

# Supabase (anon key only — never service role)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Feature flags (true | false). When unset, enabled only if Supabase is configured.
EXPO_PUBLIC_FEATURE_CLOUD_SYNC=
EXPO_PUBLIC_FEATURE_LIVE_DAILY_LEADERBOARD=
EXPO_PUBLIC_FEATURE_LIVE_RANKED=
EXPO_PUBLIC_FEATURE_CONNECTED_ECONOMY=
EXPO_PUBLIC_FEATURE_ACCOUNT_DELETION=

# --- Monetization (public client config only) ---
# Master toggles (true | false). Dev/preview defaults enable test ads & mock purchases.
EXPO_PUBLIC_ADS_ENABLED=
EXPO_PUBLIC_PURCHASES_ENABLED=
EXPO_PUBLIC_SUBSCRIPTIONS_ENABLED=
EXPO_PUBLIC_PERSONALIZED_ADS_ENABLED=
EXPO_PUBLIC_REWARDED_AD_SSV_ENABLED=

# AdMob app IDs (ca-app-pub-XXXX~YYYY) and ad unit IDs (ca-app-pub-XXXX/ZZZZ)
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=
EXPO_PUBLIC_ADMOB_IOS_APP_ID=
EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_UNIT_ID=
EXPO_PUBLIC_ADMOB_IOS_REWARDED_UNIT_ID=
EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL_UNIT_ID=
EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL_UNIT_ID=

# RevenueCat public SDK keys (platform-specific)
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=

# Rewarded ad SSV verification secrets and webhook URLs are SERVER-ONLY — never EXPO_PUBLIC_*.

# --- Live Ops ---
# development | preview | closed-beta | production
EXPO_PUBLIC_RELEASE_CHANNEL=
# Dev-only maintenance bypass (never ship enabled in production)
EXPO_PUBLIC_LIVEOPS_BYPASS_MAINTENANCE=false
EXPO_PUBLIC_SUPPORT_URL=
EXPO_PUBLIC_ANDROID_STORE_URL=
EXPO_PUBLIC_IOS_STORE_URL=
